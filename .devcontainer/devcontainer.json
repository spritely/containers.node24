// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/dotnet
{
    "name": "containers.node24",

    // Set environment variable DEVCONTAINER_MODE=dev to layer in the compose.dev.yaml
    // This adds a proxy to protect credentials when agents are running.
    // When unset such as on CI, it falls back to the compose.ci.yaml no-op setup.
    "dockerComposeFile": ["compose.yaml", "compose.${localEnv:DEVCONTAINER_MODE:ci}.yaml"],
    "service": "dev",
    "workspaceFolder": "/src",
    "postCreateCommand": "post-create",

    // Features to add to the dev container. More info: https://containers.dev/features.
    // "features": {},

    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "bierner.github-markdown-preview",
                "davidanson.vscode-markdownlint",
                "editorconfig.editorconfig",
                "humao.rest-client",
                "mhutchie.git-graph",
                "ms-python.python",
                "openai.chatgpt",
                "ryanluker.vscode-coverage-gutters",
                "streetsidesoftware.code-spell-checker",
                "yzhang.markdown-all-in-one"
            ]
        }
    }
}
